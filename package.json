{
    "name": "fubbik",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "typescript": "^5",
            "@types/bun": "^1.3.9",
            "elysia": "^1.4.21",
            "better-auth": "^1.5.1",
            "arktype": "^2.1.29",
            "vitest": "^3.1.1",
            "@vitest/ui": "^3.1.1",
            "@vitest/coverage-v8": "^3.1.1",
            "jsdom": "^26.0.0"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "check-types": "turbo run check-types",
        "dev:native": "turbo run dev --filter=native",
        "dev:web": "turbo run dev --filter=web",
        "dev:server": "turbo run dev --filter=server",
        "db:push": "turbo run db:push --filter=@fubbik/db",
        "db:studio": "turbo run db:studio --filter=@fubbik/db",
        "db:generate": "turbo run db:generate --filter=@fubbik/db",
        "db:migrate": "turbo run db:migrate --filter=@fubbik/db",
        "db:start": "turbo run db:start --filter=@fubbik/db",
        "db:watch": "turbo run db:watch --filter=@fubbik/db",
        "db:stop": "turbo run db:stop --filter=@fubbik/db",
        "db:down": "turbo run db:down --filter=@fubbik/db",
        "seed": "turbo run seed --filter=@fubbik/db",
        "scan": "turbo run scan --filter=@fubbik/db",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt --write .",
        "fmt:check": "oxfmt --check .",
        "sherif": "sherif",
        "sherif:fix": "sherif --fix",
        "ci": "turbo run check-types lint test build && pnpm run fmt:check && pnpm run sherif",
        "ci:fix": "turbo run check-types lint test build && pnpm run fmt && pnpm run sherif --fix && pnpm run lint:fix"
    },
    "devDependencies": {
        "@fubbik/config": "workspace:*",
        "@fubbik/env": "workspace:*",
        "@types/bun": "catalog:",
        "@typescript/native-preview": "latest",
        "dotenv": "catalog:",
        "knip": "^5.85.0",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "sherif": "^1.10.0",
        "turbo": "^2.6.3",
        "typescript": "catalog:"
    },
    "overrides": {
        "@prisma/client": "npm:empty-npm-package@1.0.0",
        "prisma": "npm:empty-npm-package@1.0.0"
    },
    "packageManager": "pnpm@10.10.0"
}
