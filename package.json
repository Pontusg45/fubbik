{
  "name": "fubbik",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "typescript": "^5",
      "@types/bun": "^1.3.9",
      "elysia": "^1.4.21",
      "better-auth": "^1.5.1",
      "arktype": "^2.1.29",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @fubbik/db db:push",
    "db:studio": "turbo -F @fubbik/db db:studio",
    "db:generate": "turbo -F @fubbik/db db:generate",
    "db:migrate": "turbo -F @fubbik/db db:migrate",
    "db:start": "turbo -F @fubbik/db db:start",
    "db:watch": "turbo -F @fubbik/db db:watch",
    "db:stop": "turbo -F @fubbik/db db:stop",
    "db:down": "turbo -F @fubbik/db db:down",
    "test": "turbo test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "sherif": "sherif",
    "sherif:fix": "sherif --fix",
    "knip": "knip"
  },
  "devDependencies": {
    "@fubbik/config": "workspace:*",
    "@fubbik/env": "workspace:*",
    "@types/bun": "catalog:",
    "dotenv": "catalog:",
    "knip": "^5.85.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sherif": "^1.10.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}