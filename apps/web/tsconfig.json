{
    "extends": "../../packages/config/tsconfig.base.json",
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["e2e", "playwright.config.ts"],
    "compilerOptions": {
        "target": "ES2022",
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "noUncheckedSideEffectImports": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
