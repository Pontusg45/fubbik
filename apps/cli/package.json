{
    "name": "cli",
    "version": "0.0.1",
    "bin": {
        "fubbik": "dist/fubbik"
    },
    "type": "module",
    "scripts": {
        "build": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile dist/fubbik",
        "start": "bun run src/index.ts",
        "check-types": "tsgo -b",
        "lint": "oxlint src"
    },
    "dependencies": {
        "commander": "^13.1.0"
    },
    "devDependencies": {
        "@fubbik/config": "workspace:*",
        "@types/bun": "catalog:",
        "typescript": "catalog:"
    }
}
