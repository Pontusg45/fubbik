{
    "name": "@fubbik/db",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./schema/auth": "./src/schema/auth.ts",
        "./schema/chunk": "./src/schema/chunk.ts",
        "./repository": "./src/repository/index.ts",
        "./errors": "./src/errors.ts"
    },
    "scripts": {
        "lint": "oxlint src",
        "db:seed": "bun run src/seed.ts",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
        "db:migrate": "drizzle-kit migrate",
        "db:start": "docker compose up -d",
        "db:watch": "docker compose up",
        "db:stop": "docker compose stop",
        "db:down": "docker compose down",
        "test": "vitest run"
    },
    "dependencies": {
        "@fubbik/env": "workspace:*",
        "dotenv": "catalog:",
        "drizzle-orm": "^0.45.1",
        "effect": "^3.19.19",
        "pg": "^8.16.3"
    },
    "devDependencies": {
        "@fubbik/config": "workspace:*",
        "@types/pg": "^8.18.0",
        "drizzle-kit": "^0.31.9",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
