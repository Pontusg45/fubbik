{
    "name": "@fubbik/db",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./schema/auth": "./src/schema/auth.ts",
        "./schema/chunk": "./src/schema/chunk.ts",
        "./schema/requirement": "./src/schema/requirement.ts",
        "./schema/plan": "./src/schema/plan.ts",
        "./repository": "./src/repository/index.ts",
        "./repository/plan": "./src/repository/plan.ts",
        "./errors": "./src/errors.ts"
    },
    "scripts": {
        "lint": "oxlint src",
        "seed": "bun run src/seed.ts",
        "scan": "bun run src/scan.ts",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
        "db:migrate": "drizzle-kit migrate",
        "db:start": "docker compose -f ../../docker-compose.yml up db -d",
        "db:watch": "docker compose -f ../../docker-compose.yml up db",
        "db:stop": "docker compose -f ../../docker-compose.yml stop db",
        "db:down": "docker compose -f ../../docker-compose.yml down db",
        "db:migrate:trgm": "psql $DATABASE_URL -f src/migrations/0002_add_trgm.sql",
        "age:setup": "bun run src/age/setup.ts",
        "test": "vitest run"
    },
    "dependencies": {
        "@fubbik/env": "workspace:*",
        "dotenv": "catalog:",
        "drizzle-orm": "^0.45.2",
        "effect": "^3.21.0",
        "pg": "^8.16.3"
    },
    "devDependencies": {
        "@fubbik/config": "workspace:*",
        "@types/pg": "^8.18.0",
        "drizzle-kit": "^0.31.9",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
